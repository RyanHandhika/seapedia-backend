// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SELLER
  BUYER
  DRIVER
}

enum DeliveryMethod {
  INSTANT
  NEXT_DAY
  REGULAR
}

enum OrderStatus {
  SEDANG_DIKEMAS
  MENUNGGU_PENGIRIM
  SEDANG_DIKIRIM
  PESANAN_SELESAI
  DIKEMBALIKAN
}

enum DeliveryJobStatus {
  AVAILABLE
  TAKEN
  COMPLETED
}

enum WalletTransactionType {
  TOPUP
  PAYMENT
  REFUND
}

enum DiscountType {
  VOUCHER
  PROMO
  NONE
}

enum DiscountValueType {
  PERCENT
  FIXED
}

// Authentication

model User {
  id           String     @id @default(uuid())
  username     String     @unique
  email        String     @unique
  passwordHash String     @map("password_hash")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  userRoles         UserRole[]
  store             Store?
  wallet            Wallet?
  addresses         Address[]
  cart              Cart?
  orders            Order[]
  appReviews        AppReview[]
  deliveryJobs      DeliveryJob[]
  driverEarnings    DriverEarning[]

  @@map("users")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  role      Role
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

// Store & Product

model Store {
  id          String   @id @default(uuid())
  sellerId    String   @unique @map("seller_id")
  storeName   String   @unique @map("store_name")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  seller   User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  products Product[]
  carts    Cart[]
  orders   Order[]

  @@map("stores")
}

model Product {
  id          String   @id @default(uuid())
  storeId     String   @map("store_id")
  name        String
  description String?
  price       Decimal  @db.Decimal(12, 2)
  stock       Int      @default(0)
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  store      Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("products")
}

// App Reviews

model AppReview {
  id           String   @id @default(uuid())
  reviewerName String   @map("reviewer_name")
  rating       Int // 1-5
  comment      String
  userId       String?  @map("user_id") // nullable: guest can submit too
  createdAt    DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("app_reviews")
}

// Payments

model Wallet {
  id        String   @id @default(uuid())
  buyerId   String   @unique @map("buyer_id")
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt DateTime @updatedAt @map("updated_at")

  buyer        User                  @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String                @id @default(uuid())
  walletId    String                @map("wallet_id")
  type        WalletTransactionType
  amount      Decimal               @db.Decimal(12, 2)
  description String?
  createdAt   DateTime              @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("wallet_transactions")
}

model Address {
  id            String   @id @default(uuid())
  buyerId       String   @map("buyer_id")
  label         String // e.g. "Home", "Office"
  recipientName String   @map("recipient_name")
  phone         String
  fullAddress   String   @map("full_address")
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  buyer  User    @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

model Cart {
  id        String   @id @default(uuid())
  buyerId   String   @unique @map("buyer_id")
  storeId   String?  @map("store_id") // null if cart is empty
  updatedAt DateTime @updatedAt @map("updated_at")

  buyer     User       @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  store     Store?     @relation(fields: [storeId], references: [id], onDelete: SetNull)
  cartItems CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String   @map("cart_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  updatedAt DateTime @updatedAt @map("updated_at")

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("cart_items")
}

// Discounts

model Voucher {
  id             String            @id @default(uuid())
  code           String            @unique
  discountType   DiscountValueType @map("discount_type")
  value          Decimal           @db.Decimal(10, 2) // percent or fixed amount
  expiryDate     DateTime          @map("expiry_date")
  usageLimit     Int               @map("usage_limit")
  usedCount      Int               @default(0) @map("used_count")
  createdAt      DateTime          @default(now()) @map("created_at")

  orders Order[]

  @@map("vouchers")
}

model Promo {
  id           String            @id @default(uuid())
  code         String            @unique
  discountType DiscountValueType @map("discount_type")
  value        Decimal           @db.Decimal(10, 2)
  expiryDate   DateTime          @map("expiry_date")
  description  String?
  createdAt    DateTime          @default(now()) @map("created_at")

  orders Order[]

  @@map("promos")
}

// Orders

model Order {
  id               String         @id @default(uuid())
  buyerId          String         @map("buyer_id")
  storeId          String         @map("store_id")
  addressId        String         @map("address_id")
  subtotal         Decimal        @db.Decimal(12, 2)
  discountAmount   Decimal        @default(0) @map("discount_amount") @db.Decimal(12, 2)
  discountType     DiscountType   @default(NONE) @map("discount_type")
  voucherId        String?        @map("voucher_id")
  promoId          String?        @map("promo_id")
  deliveryMethod   DeliveryMethod @map("delivery_method")
  deliveryFee      Decimal        @map("delivery_fee") @db.Decimal(12, 2)
  ppnAmount        Decimal        @map("ppn_amount") @db.Decimal(12, 2) // 12%
  total            Decimal        @db.Decimal(12, 2)
  status           OrderStatus    @default(SEDANG_DIKEMAS)
  overdueCheckedAt DateTime?      @map("overdue_checked_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  buyer         User                @relation(fields: [buyerId], references: [id])
  store         Store               @relation(fields: [storeId], references: [id])
  address       Address             @relation(fields: [addressId], references: [id])
  voucher       Voucher?            @relation(fields: [voucherId], references: [id])
  promo         Promo?              @relation(fields: [promoId], references: [id])
  orderItems    OrderItem[]
  statusHistory OrderStatusHistory[]
  deliveryJob   DeliveryJob?

  @@map("orders")
}

model OrderItem {
  id               String  @id @default(uuid())
  orderId          String  @map("order_id")
  productId        String  @map("product_id")
  quantity         Int
  priceAtPurchase  Decimal @map("price_at_purchase") @db.Decimal(12, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String      @map("order_id")
  status    OrderStatus
  note      String?
  changedAt DateTime    @default(now()) @map("changed_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_history")
}

// Driver

model DeliveryJob {
  id          String            @id @default(uuid())
  orderId     String            @unique @map("order_id")
  driverId    String?           @map("driver_id") // null until a driver takes it
  status      DeliveryJobStatus @default(AVAILABLE)
  takenAt     DateTime?         @map("taken_at")
  completedAt DateTime?         @map("completed_at")
  createdAt   DateTime          @default(now()) @map("created_at")

  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver        User?          @relation(fields: [driverId], references: [id])
  driverEarning DriverEarning?

  @@map("delivery_jobs")
}

model DriverEarning {
  id            String   @id @default(uuid())
  driverId      String   @map("driver_id")
  deliveryJobId String   @unique @map("delivery_job_id")
  amount        Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  driver      User        @relation(fields: [driverId], references: [id])
  deliveryJob DeliveryJob @relation(fields: [deliveryJobId], references: [id])

  @@map("driver_earnings")
}

// Testing (Simulated Date)

model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}
